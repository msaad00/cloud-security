{
  "Comment": "Lambda 1 (Parser) execution role — least privilege",
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "ReadManifestFromS3",
      "Effect": "Allow",
      "Action": [
        "s3:GetObject"
      ],
      "Resource": "arn:aws:s3:::${IAM_REMEDIATION_BUCKET}/departures/*"
    },
    {
      "Sid": "ReadChangeDetectionHash",
      "Effect": "Allow",
      "Action": [
        "s3:GetObject"
      ],
      "Resource": "arn:aws:s3:::${IAM_REMEDIATION_BUCKET}/departures/.last_hash"
    },
    {
      "Sid": "AssumeRoleInTargetAccounts",
      "Effect": "Allow",
      "Action": "sts:AssumeRole",
      "Resource": "arn:aws:iam::*:role/${IAM_CROSS_ACCOUNT_ROLE}",
      "Condition": {
        "StringEquals": {
          "aws:PrincipalOrgID": "${AWS_ORG_ID}"
        }
      },
      "_comment": "Parser calls iam:GetUser ONLY through credentials returned by this STS AssumeRole. The cross-account role (cross_account_remediation_role.json) carries the enumerated IAM read permissions. No direct iam:* grant on this role."
    },
    {
      "Sid": "DenyAllDirectIAMActions_WILDCARD_OK",
      "Effect": "Deny",
      "Action": "iam:*",
      "Resource": "*",
      "_comment": "WILDCARD_OK: Deny on iam:* for Resource:* is defense in depth. Deny is intentionally broader than any future Allow; this forces every IAM call to go through the cross-account STS path where the protected-principal deny list lives."
    },
    {
      "Sid": "DenyDirectStepFunctionExecution_WILDCARD_OK",
      "Effect": "Deny",
      "Action": "states:StartExecution",
      "Resource": "*"
    },
    {
      "Sid": "CloudWatchLogs",
      "Effect": "Allow",
      "Action": [
        "logs:CreateLogGroup",
        "logs:CreateLogStream",
        "logs:PutLogEvents"
      ],
      "Resource": "arn:aws:logs:*:*:log-group:/aws/lambda/iam-departures-parser*"
    }
  ]
}
